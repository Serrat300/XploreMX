<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/beige_claro">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_centerInParent="true"
            android:src="@drawable/logo"
            android:contentDescription="Logo" />
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recordatorios"
        android:textSize="20sp"
        android:textColor="@color/verde_oliva"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAlarmas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <Button
        android:id="@+id/btnAnadirAlarma"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Añadir alarma"
        android:textColor="@color/beige_claro"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_publicar"
        android:stateListAnimator="@null"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="28dp"
        android:layout_marginTop="8dp" />

</LinearLayout>