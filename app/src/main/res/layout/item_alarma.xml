<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="340dp"
    android:layout_height="100dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card_terracota"
    android:padding="16dp"
    android:minHeight="72dp"
    android:layout_marginTop="40dp"
  >

    <CheckBox
        android:id="@+id/checkAlarma"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:buttonTint="@color/beige_claro" />

    <TextView
        android:id="@+id/txtTituloAlarma"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Visita Museo"
        android:textColor="@color/beige_claro"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_toEndOf="@id/checkAlarma"
        android:layout_marginStart="8dp"
        android:layout_alignTop="@id/checkAlarma" />

    <TextView
        android:id="@+id/txtFechaAlarma"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15 Mayo – 11:00"
        android:textColor="@color/beige_claro"
        android:textSize="13sp"
        android:layout_below="@id/txtTituloAlarma"
        android:layout_toEndOf="@id/checkAlarma"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp" />

    <ImageButton
        android:id="@+id/btnEditarAlarma"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:src="@drawable/ic_edit"
        android:background="@android:color/transparent"
        android:contentDescription="Editar" />


    <ImageButton
        android:id="@+id/btnEliminarAlarma"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:src="@drawable/ic_delete"
        android:background="@android:color/transparent"
        android:contentDescription="Eliminar" />

</RelativeLayout>